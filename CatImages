<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>RAM Products — Category Image Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Barlow',sans-serif;background:#111;color:#eee;min-height:100vh}
header{background:#1a1a1a;border-bottom:3px solid #CC2229;padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:58px;position:sticky;top:0;z-index:100}
.logo{background:#CC2229;color:white;font-family:'Barlow Condensed';font-weight:800;font-size:16px;letter-spacing:.05em;padding:5px 11px}
.hsub{color:#555;font-size:12px;margin-left:12px}
#dlAllBtn{background:#CC2229;color:white;border:none;border-radius:6px;padding:7px 16px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;display:none}
.container{max-width:1100px;margin:0 auto;padding:24px 16px}

#welcome{max-width:460px;margin:48px auto;text-align:center}
.wicon{font-size:48px;margin-bottom:14px}
#welcome h2{font-family:‘Barlow Condensed’;font-weight:800;font-size:30px;color:white;margin-bottom:8px}
#welcome p{color:#888;font-size:14px;line-height:1.7;margin-bottom:24px}
.badges{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:26px}
.badge{background:#1e1e1e;border:1px solid #333;border-radius:20px;padding:6px 13px;font-size:12px;font-weight:600;color:#aaa}
.badge span{color:#4cda7a;margin-right:3px}
#startBtn{background:#CC2229;color:white;border:none;border-radius:8px;padding:14px 36px;font-size:16px;font-weight:700;cursor:pointer;font-family:inherit}

#mainScreen{display:none}
.controls{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px}
.controls h2{font-family:‘Barlow Condensed’;font-weight:800;font-size:24px;color:white}
.controls p{color:#666;font-size:13px;margin-top:2px}
.btnrow{display:flex;gap:8px}
#generateBtn{background:#CC2229;color:white;border:none;border-radius:6px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit}
#stopBtn{background:#333;color:#CC2229;border:1px solid #CC2229;border-radius:6px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:none}

#progressWrap{height:4px;background:#222;border-radius:2px;margin-bottom:18px;display:none}
#progressBar{height:100%;width:0;background:#CC2229;border-radius:2px;transition:width .5s}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px}
.card{background:#1a1a1a;border-radius:10px;overflow:hidden;border:1px solid #252525;transition:transform .15s,border-color .2s}
.card.loading{border-color:#CC2229}
.card.done{border-color:#2a2a2a;cursor:pointer}
.card.done:hover{transform:scale(1.025);border-color:#444}
.card.error{border-color:#4a1515}
.card-img{aspect-ratio:1;background:#0e0e0e;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.card.done .card-img{background:#fff}
.card-img img{width:100%;height:100%;object-fit:cover;display:block}
.spinner{width:28px;height:28px;border:2px solid #2a2a2a;border-top-color:#CC2229;border-radius:50%;animation:spin .75s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.idle-o{font-size:20px;opacity:.1;color:#888}
.errbox{text-align:center;padding:10px}
.errbox .ei{font-size:18px;margin-bottom:4px}
.errbox .et{font-size:10px;color:#f87;line-height:1.5;display:block;word-break:break-word}
.retry-sm{margin-top:6px;background:#222;color:#999;border:none;border-radius:4px;padding:4px 9px;font-size:11px;cursor:pointer;font-family:inherit}
.dl-btn{position:absolute;bottom:6px;right:6px;background:rgba(0,0,0,.72);color:white;border:none;border-radius:4px;padding:3px 8px;font-size:11px;cursor:pointer;font-family:inherit;font-weight:700}
.card-label{padding:9px 11px}
.cname{font-size:12px;font-weight:700;color:#ccc}
.cprod{font-size:10px;color:#555;margin-top:2px}

/* Lightbox */
#lb{display:none;position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:200;align-items:center;justify-content:center;padding:20px}
#lb.open{display:flex}
#lbBox{background:white;border-radius:12px;overflow:hidden;max-width:480px;width:100%}
#lbImg{width:100%;display:block}
.lbfoot{padding:13px 16px;display:flex;justify-content:space-between;align-items:center;background:white}
.lbn{font-weight:700;color:#111;font-size:14px}
.lbp{color:#999;font-size:11px;margin-top:2px}
.lbbtns{display:flex;gap:7px}
#lbRetry{background:#f0f0f0;border:none;border-radius:6px;padding:7px 13px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit}
#lbDl{background:#CC2229;color:white;border:none;border-radius:6px;padding:7px 14px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}
</style>

</head>
<body>

<header>
  <div style="display:flex;align-items:center">
    <div class="logo">RAM PRODUCTS</div>
    <span class="hsub">Category Image Generator</span>
  </div>
  <button id="dlAllBtn" onclick="downloadAll()">↓ Download All</button>
</header>

<div class="container">

  <div id="welcome">
    <div class="wicon">🏭</div>
    <h2>Category Image Generator</h2>
    <p>Generate professional product images for all 20 RAM Products categories — free, no sign-up required.</p>
    <div class="badges">
      <div class="badge"><span>✓</span>No API key</div>
      <div class="badge"><span>✓</span>Free</div>
      <div class="badge"><span>✓</span>20 categories</div>
      <div class="badge"><span>✓</span>Downloadable</div>
    </div>
    <button id="startBtn" onclick="startApp()">▶ Start Generating</button>
  </div>

  <div id="mainScreen">
    <div class="controls">
      <div>
        <h2>20 Category Images</h2>
        <p id="statusTxt">Ready — tap Generate to start</p>
      </div>
      <div class="btnrow">
        <button id="stopBtn" onclick="stopAll()">■ Stop</button>
        <button id="generateBtn" onclick="generateAll()">▶ Generate All 20</button>
      </div>
    </div>
    <div id="progressWrap"><div id="progressBar"></div></div>
    <div class="grid" id="grid"></div>
  </div>

</div>

<div id="lb" onclick="closeLb()">
  <div id="lbBox" onclick="event.stopPropagation()">
    <img id="lbImg" src="" alt=""/>
    <div class="lbfoot">
      <div><div class="lbn" id="lbn"></div><div class="lbp" id="lbp"></div></div>
      <div class="lbbtns">
        <button id="lbRetry" onclick="retryLb()">↺ Retry</button>
        <button id="lbDl" onclick="dlLb()">↓ Save</button>
      </div>
    </div>
  </div>
</div>

<script>
const CATS = [
  {name:"Fasteners",           prod:"Hex Head Bolt",          prompt:"single stainless steel hex bolt upright, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Abrasives",           prod:"Grinding Wheel",         prompt:"single gray industrial grinding wheel angled, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Assortments & Kits",  prod:"Hardware Assortment Kit",prompt:"open compartmented hardware organizer case with bolts screws nuts, professional product photo, pure white background, studio lighting, no text, photorealistic"},
  {name:"Cable Ties & Mounts", prod:"Nylon Cable Ties",       prompt:"bundle of black nylon zip ties fanned out, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Chemicals & Paint",   prod:"Aerosol Spray Can",      prompt:"single industrial aerosol spray can upright plain gray, professional product photo, pure white background, studio lighting, clean shadow, photorealistic"},
  {name:"Circuit Protection",  prod:"Blade Fuse",             prompt:"single automotive blade fuse macro translucent body metal element inside, professional product photo, pure white background, studio lighting, no text, photorealistic"},
  {name:"Clips & Clamps",      prod:"C-Clamp",                prompt:"single cast iron C-clamp angled view, professional product photo, pure white background, studio lighting, clean shadow, no text, photorealistic"},
  {name:"Cutting Tools",       prod:"Utility Knife",          prompt:"single heavy duty utility knife blade slightly extended diagonal, professional product photo, pure white background, studio lighting, no text, photorealistic"},
  {name:"Electrical",          prod:"Wire Connector Nuts",    prompt:"three orange wire connector nuts clustered, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Fleet & Automotive",  prod:"Oil Filter",             prompt:"single automotive oil filter cylindrical upright no branding, professional product photo, pure white background, studio lighting, clean shadow, photorealistic"},
  {name:"Hose & Tubing",       prod:"Coiled Air Hose",        prompt:"single coiled red pneumatic air hose brass fittings, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Hydraulics",          prod:"Hydraulic Fitting",      prompt:"single brass hydraulic fitting threaded body hex collar upright macro, professional product photo, pure white background, studio lighting, no text, photorealistic"},
  {name:"Pipe & Tube Fittings",prod:"Pipe Elbow Fitting",     prompt:"single galvanized steel 90-degree pipe elbow fitting, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Safety & Protection", prod:"Safety Glasses",         prompt:"single pair clear lens safety glasses temples open, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Shop Supplies",       prod:"Shop Towel Roll",         prompt:"single roll blue shop towels upright, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Storage & Organization",prod:"Parts Cabinet",        prompt:"single small red metal multi-drawer parts cabinet three-quarter view, professional product photo, pure white background, studio lighting, no text, photorealistic"},
  {name:"Tools & Equipment",   prod:"Ratchet Wrench",         prompt:"single chrome ratchet wrench diagonal, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Welding",             prod:"Welding Helmet",         prompt:"single auto-darkening welding helmet front-facing dark lens, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Wire & Cable",        prod:"Electrical Wire Spool",  prompt:"single spool yellow electrical wire upright, professional product photo, pure white background, studio lighting, subtle shadow, no text, photorealistic"},
  {name:"Wire Management",     prod:"Cable Raceway",          prompt:"single white plastic cable raceway duct cover open showing channel diagonal, professional product photo, pure white background, studio lighting, no text, photorealistic"},
];

let imgs = CATS.map(()=>({status:'idle',url:null,err:null}));
let running=false, stopFlag=false, lbIdx=null;

function makeUrl(prompt){
  const seed = Math.floor(Math.random()*999999);
  const full = prompt + ', white background, no watermark, no signature';
  return `https://image.pollinations.ai/prompt/${encodeURIComponent(full)}?width=512&height=512&seed=${seed}&nologo=true&enhance=true&model=flux`;
}

function startApp(){
  document.getElementById('welcome').style.display='none';
  document.getElementById('mainScreen').style.display='block';
  buildGrid();
}

function buildGrid(){
  const g=document.getElementById('grid'); g.innerHTML='';
  CATS.forEach((c,i)=>{
    const d=document.createElement('div');
    d.className='card'; d.id=`c${i}`;
    d.innerHTML=`<div class="card-img" id="ci${i}"><span class="idle-o">○</span></div>
      <div class="card-label"><div class="cname">${c.name}</div><div class="cprod">${c.prod}</div></div>`;
    d.onclick=()=>{ if(imgs[i].status==='done') openLb(i); };
    g.appendChild(d);
  });
}

function setCard(i,status,url,err){
  imgs[i]={status,url,err};
  const card=document.getElementById(`c${i}`);
  const ci=document.getElementById(`ci${i}`);
  card.className=`card ${status}`;
  if(status==='idle') ci.innerHTML=`<span class="idle-o">○</span>`;
  else if(status==='loading') ci.innerHTML=`<div class="spinner"></div>`;
  else if(status==='done') ci.innerHTML=`<img src="${url}" alt="${CATS[i].name}"/><button class="dl-btn" onclick="event.stopPropagation();dlImg(${i})">↓</button>`;
  else{
    ci.innerHTML=`<div class="errbox"><div class="ei">⚠️</div><span class="et">${(err||'Failed').slice(0,100)}</span><button class="retry-sm" onclick="event.stopPropagation();genOne(${i})">↺ Retry</button></div>`;
  }
  updateUI();
}

function updateUI(){
  const done=imgs.filter(x=>x.status==='done').length;
  const errs=imgs.filter(x=>x.status==='error').length;
  const total=CATS.length;
  document.getElementById('statusTxt').textContent =
    running ? `Generating… ${done} of ${total} complete` :
    done===0 ? 'Ready — tap Generate to start' :
    `${done} of ${total} done${errs>0?` · ${errs} failed — tap ↺ to retry`:''}`;
  const db=document.getElementById('dlAllBtn');
  db.style.display=done>0?'block':'none';
  db.textContent=`↓ Download All (${done})`;
  const pw=document.getElementById('progressWrap');
  if(done>0||running){
    pw.style.display='block';
    document.getElementById('progressBar').style.width=`${(done/total)*100}%`;
  }
}

async function genOne(i){
  setCard(i,'loading',null,null);
  const url = makeUrl(CATS[i].prompt);
  try {
    // Fetch as blob — avoids all CORS/security issues with local HTML files
    const res = await fetch(url);
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    const blob = await res.blob();
    const blobUrl = URL.createObjectURL(blob);
    setCard(i,'done',blobUrl,null);
  } catch(e){
    setCard(i,'error',null, e.message || 'Network error — check internet connection');
  }
}

async function generateAll(){
  if(running) return;
  stopFlag=false; running=true;
  imgs=CATS.map(()=>({status:'idle',url:null,err:null}));
  buildGrid();
  document.getElementById('generateBtn').style.display='none';
  document.getElementById('stopBtn').style.display='inline-block';
  updateUI();
  for(let i=0;i<CATS.length;i++){
    if(stopFlag) break;
    await genOne(i);
    if(i<CATS.length-1) await new Promise(r=>setTimeout(r,400));
  }
  running=false;
  document.getElementById('generateBtn').style.display='inline-block';
  document.getElementById('generateBtn').textContent='↺ Regenerate All';
  document.getElementById('stopBtn').style.display='none';
  updateUI();
}

function stopAll(){
  stopFlag=true; running=false;
  document.getElementById('generateBtn').style.display='inline-block';
  document.getElementById('stopBtn').style.display='none';
  updateUI();
}

function dlImg(i){
  const url=imgs[i].url; if(!url) return;
  const a=document.createElement('a');
  a.href=url;
  a.download=CATS[i].name.replace(/[^a-z0-9]/gi,'_').toLowerCase()+'.png';
  a.click();
}
function downloadAll(){ imgs.forEach((x,i)=>{ if(x.status==='done') setTimeout(()=>dlImg(i),i*200); }); }

function openLb(i){
  lbIdx=i;
  document.getElementById('lbImg').src=imgs[i].url;
  document.getElementById('lbn').textContent=CATS[i].name;
  document.getElementById('lbp').textContent=CATS[i].prod;
  document.getElementById('lb').classList.add('open');
}
function closeLb(){ document.getElementById('lb').classList.remove('open'); lbIdx=null; }
async function retryLb(){ const i=lbIdx; closeLb(); await genOne(i); }
function dlLb(){ if(lbIdx!==null) dlImg(lbIdx); }
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeLb(); });
</script>

</body>
</html>
